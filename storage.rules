rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Default deny for all files not explicitly matched
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Academic Resource e-Library access paths
    match /ebooks {
      match /pdfs/{fileName} {
        // Publicly readable so students can access, read and analyze documents
        allow read: if true;
        
        // Enforce maximum size under 50MB, allow unauthenticated/test writes during development sandbox
        allow create, update: if request.resource.size < 50 * 1024 * 1024;
          
        // Deletion permitted for admin/moderator actions
        allow delete: if true;
      }

      match /covers/{fileName} {
        // Cover portrait images are publicly readable to generate library grid previews
        allow read: if true;
        
        // Cover upload max size under 10MB
        allow create, update: if request.resource.size < 10 * 1024 * 1024;
          
        // Deletion permitted
        allow delete: if true;
      }
    }

    // Courses and Curriculum assets (including direct uploads for Course Thumbnails)
    match /courses {
      match /thumbnails/{fileName} {
        // Course thumbnail images are publicly readable
        allow read: if true;
        
        // Thumbnail upload limit of 10MB
        allow create, update: if request.resource.size < 10 * 1024 * 1024;
        
        // Deletion permitted
        allow delete: if true;
      }
    }

    // Declassified Forensic Case studies, evidence files, and attachments
    match /cases {
      match /{allPaths=**} {
        // Publicly readable so investigative dashboards can fetch evidence
        allow read: if true;

        // Image & PDF upload max size of 20MB
        allow create, update: if request.resource.size < 20 * 1024 * 1024;

        // Allow deletion for case updates
        allow delete: if true;
      }
    }

    // Doubts and community discussion images and attachments
    match /doubts {
      match /{allPaths=**} {
        // Publicly readable for the community forum
        allow read: if true;

        // Image upload max size of 15MB
        allow create, update: if request.resource.size < 15 * 1024 * 1024;

        // Allow deletion
        allow delete: if true;
      }
    }

    // Default uploads folder cache
    match /uploads {
      match /{allPaths=**} {
        allow read: if true;
        allow create, update: if request.resource.size < 50 * 1024 * 1024;
        allow delete: if true;
      }
    }
  }
}
